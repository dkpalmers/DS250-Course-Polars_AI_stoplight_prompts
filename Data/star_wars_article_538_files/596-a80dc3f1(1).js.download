		mask-size: contain;
		-webkit-mask-size: contain;
		width: var(--play-button-svg-before--width);
		background: var(--play-button-svg-before--background-color);
		height: var(--play-button-svg--height);
	}

	.end-card-overlay__live-indicator {
		display: var(--live-indicator--display);
		position: var(--live-indicator--position);
		align-items: var(--live-indicator--align-items);
		justify-content: var(--live-indicator--justify-content);
		padding-left: var(--live-indicator--padding-left);
		gap: var(--live-indicator--gap);
		width: var(--live-indicator--width);
		height: var(--live-indicator--height);
		background-color: var(--live-indicator--background-color);
		border-radius: var(--live-indicator--border-radius);
		bottom: var(--live-indicator--bottom);
		left: var(--live-indicator--left);
		color: var(--live-indicator--color);
		font-size: var(--live-indicator--font-size);
		font-style: var(--live-indicator--font-style);
		font-weight: var(--live-indicator--font-weight);
		line-height: var(--live-indicator--line-height);
