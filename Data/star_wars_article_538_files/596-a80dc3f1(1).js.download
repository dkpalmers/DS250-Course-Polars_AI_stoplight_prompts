	:host {
		--control--hover--transform: scale(1.0455);
		--control--pressed--transform: unset;
	}

	[hidden] {
		display: none;
	}

	.controls-container {
		opacity: 0;
		transition-timing-function: cubic-bezier(0.42, 0, 1, 1);
		transition-property: opacity, translate;

		&.visible {
			transition-duration: 0.2s;
			opacity: 1;
			translate: 0 0;
		}

		&.hidden {
			transition-duration: 0.4s;

			.controls-footer {
				transition: translate 0.4s linear;
				translate: 0 40px;
			}
		}

		keyboard-actions {
			position: absolute;
		}

		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		flex-direction: column;
		overflow: hidden;
		height: 100%;
		width: 100%;
		position: relative;
		top: 0;
		left: 0;
		bottom: 0;
		right: 0;
		pointer-events: auto;
		box-sizing: border-box;
		padding: var(--controls-container--padding);

		&:after {
			content: "";
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: var(--controls-container__after--height);
			background: var(--controls-container__after--background);
			z-index: 1;
			pointer-events: none;
		}

		.program-decoration {
			display: flex;
			position: absolute;
			top: 0;
			right: 0;
			bottom: 0;
			left: 0;
			align-items: end;
			background: rgba(0, 0, 0, 0.75);
			padding: 0 0 104px 16px;

			program-decoration {
				max-width: 525px;
			}
		}
	}

	.controls-header {
		display: flex;
		flex-direction: column;
		padding: 16px 0px 24px;
		width: 100%;
		height: auto;
		min-height: auto;
		justify-content: flex-start;
	}

	.controls-sub-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0;
	}

	.header-info {
		display: flex;
		gap: 10px;
	}

	.aux-controls {
		display: flex;
		gap: 10px;
	}

	.controls-center {
		display: flex;
		flex-direction: row;
		padding: 0;
		width: 100%;
		height: auto;
		min-height: auto;
		justify-content: center;
		z-index: 2;

		.playback-controls-narrow quick-rewind,
		.playback-controls-narrow quick-fast-forward {
			padding: 8px;
		}

		.playback-controls-narrow toggle-play-pause {
			padding: 4px;
		}

		.playback-controls-narrow {
			display: var(--playback-controls-narrow--display);
			justify-content: center;
			align-items: center;
			gap: 12px;
		}
	}

	.controls-footer {
		display: flex;
		flex-direction: column;
		width: 100%;
		height: auto;
		gap: var(--controls-footer--gap);
		margin-top: 0;
		justify-content: space-between;
		z-index: 2;
		margin-bottom: 0;
	}

	.controls-sub-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0;
		z-index: 3;
	}

	.volume-controls {
		display: flex;
		gap: 10px;
		position: relative;
		height: auto;
		bottom: auto;
		left: auto;
		right: auto;
		top: auto;
		transform: none;
		align-items: center;
		justify-content: flex-start;
		margin: 0 auto 0 0;
		padding: 0;
		min-width: 130px;
	}

	.experience-controls {
		display: var(--experience-controls--display);
		justify-content: flex-end;
		margin-left: auto;
	}

	.volume-controls > *,
	.experience-controls-narrow > *,
	.experience-controls > * {
		padding: 8px;
	}

	.experience-controls,
	.experience-controls-narrow,
	.experience-controls-left,
	.volume-controls {
		gap: 4px;
		flex: 1;
	}

	.experience-controls-narrow {
		display: var(--experience-controls-narrow--display);
		gap: 12px;
		justify-content: flex-end;
	}

	.playback-controls-narrow .live {
		--toggle-play-pause-size: 44px;
	}

	.experience-controls-extra-narrow {
		display: var(--experience-controls-extra-narrow--display);
		gap: 12px;
		justify-content: flex-end;
	}

	.playback-controls-wide quick-rewind,
	.playback-controls-wide quick-fast-forward {
		padding: 8px;
	}

	.playback-controls-wide toggle-play-pause {
		padding: 4px;
	}

	.playback-controls-wide {
		--toggle-play-pause-size: 36px;
		--quick-controls-size: 28px;

		display: var(--playback-controls-wide--display);
		justify-content: center;
		align-items: center;
		gap: 12px;
	}

	.transport-controls {
		color: white;
		display: flex;
		padding: 0 8px;
		box-sizing: border-box;
		position: relative;
		bottom: auto;
		left: auto;
		right: auto;
		top: auto;
		align-items: center;
		width: 100%;
		margin: 0;
		gap: 9px;
	}

	current-time-indicator,
	total-duration {
		font-variant-numeric: tabular-nums;
		text-align: center;
		flex: 0 0 4ch;
	}

	.controls-container.hide-controls.settings-open {
		.controls-header,
		.controls-center,
		.transport-controls,
		.volume-controls,
		.playback-controls-narrow,
		.playback-controls-wide,
		share-modal-control,
		toggle-captions,
		toggle-fullscreen,
		debug-control {
			display: none;
		}

		.experience-controls {
			display: flex;
			justify-content: center;
			width: 100%;
		}
	}

	.controls-container.hide-controls.share-open {
