	.styled-radio-buttons {
		display: flex;
		flex-wrap: var(--styled-radio-buttons--flex-wrap);
		justify-content: var(--styled-radio-buttons--justify-content);
		gap: var(--styled-radio-buttons--gap);
		padding: var(--styled-radio-buttons--padding);
		margin: var(--styled-radio-buttons--margin);
		border: none;
	}

	.styled-radio-input {
		border: 0;
		clip: rect(0 0 0 0);
		width: 1px;
		height: 1px;
		margin: -1px;
		overflow: hidden;
		padding: 0;
		position: absolute;
		top: 0;
		left: 0;
	}

	.styled-radio-input + .styled-radio {
		display: inline-block;
		box-sizing: border-box;
		width: var(
			--styled-radio-buttons__styled-radio--size,
			var(--styled-radio-buttons__styled-radio--width)
		);
		height: var(
			--styled-radio-buttons__styled-radio--size,
			var(--styled-radio-buttons__styled-radio--height)
		);
		cursor: pointer;
		background-color: var(
			--styled-radio-buttons__styled-radio--background-color
		);
		padding: var(--styled-radio-buttons__styled-radio--padding);
		background-size: var(--styled-radio-buttons__styled-radio--background-size);

		&.circle {
			border-radius: 50%;
		}

		&.rounded-square {
			border-radius: var(--styled-radio-buttons__styled-radio--border-radius);
		}

		&.has-before::before {
			display: block;
			width: 100%;
			height: 100%;
			content: var(--styled-radio-buttons__styled-radio__before--content);

			overflow: hidden;
			color: var(--styled-radio-buttons__styled-radio__before--color,);
			text-overflow: ellipsis;
			font-family: var(
				--styled-radio-buttons__styled-radio__before--font-family
			);
			font-size: var(--styled-radio-buttons__styled-radio__before--font-size);
			font-weight: var(
				--styled-radio-buttons__styled-radio__before--font-weight
			);
			line-height: var(
				--styled-radio-buttons__styled-radio__before--line-height
			);
			letter-spacing: var(
				--styled-radio-buttons__styled-radio__before--letter-spacing
			);
		}
	}

	.styled-radio-input:checked + .styled-radio {
		outline: var(--styled-radio-buttons__styled-radio--outline);
	}

	input.styled-radio-input:focus + .styled-radio {
		outline: var(--styled-radio-buttons__styled-radio--focused-outline);
	}

	.styled-radio-label {
		display: none;
	}
