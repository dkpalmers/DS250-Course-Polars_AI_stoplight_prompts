		margin: var(--countdown-text--margin);
		font-family: var(--countdown-text--font-family);
		font-size: var(--countdown-text--font-size);
		font-weight: var(--countdown-text--font-weight);
		line-height: var(--countdown-text--line-height);
	}

	.end-card-overlay__main-title {
		display: var(--main-title--display);
		color: #fff;
		margin: 0px;
		font-family: var(--main-title-font-family);
		font-size: var(--main-title--font-size);
		font-weight: var(--main-title--font-weight);
		line-height: var(--main-title--line-height);
