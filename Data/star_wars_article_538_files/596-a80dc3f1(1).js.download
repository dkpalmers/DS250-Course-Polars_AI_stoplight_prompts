	:host {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 3;
		pointer-events: none;
		display: none;
	}

	:host:has(.casting-tutorial-overlay) {
		display: block;
	}

	.casting-tutorial-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		display: flex;
		flex-direction: column;
		background-color: rgba(0, 0, 0, 0.7);
		pointer-events: auto;
		z-index: 3;
	}

	.casting-tutorial-overlay-button-indicator {
		pointer-events: auto;
	}

	.casting-tutorial-overlay-header {
		display: flex;
		flex: 0 0 auto;
		justify-content: space-between;
		align-items: flex-start;
		padding: 20px;
	}

	.casting-tutorial-overlay-spacer {
		flex: 1;
	}

	.casting-tutorial-overlay-button-indicator {
		flex: 0 0 auto;
	}

	.casting-tutorial-overlay-body {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 20px;
	}

	.casting-tutorial-overlay-instructions {
		font-size: 32px;
		text-align: center;
		margin-bottom: 24px;
		color: var(--casting-tutorial-overlay--text-color, #ffffff);
	}

	.casting-tutorial-confirmation-button {
		width: 326px;
		height: 48px;
		border: none;
		border-radius: 4px;
		background-color: var(
			--casting-tutorial-overlay-button--background-color,
			#0072d2
		);
		color: var(--casting-tutorial-overlay-button--text-color, #ffffff);
		pointer-events: auto;
		align-self: center;
		padding: 12px 24px;
		font-size: 15px;
		font-weight: 900;
		font-style: normal;
		font-stretch: normal;
		line-height: 1.6;
		letter-spacing: 1.5px;
		text-align: center;
