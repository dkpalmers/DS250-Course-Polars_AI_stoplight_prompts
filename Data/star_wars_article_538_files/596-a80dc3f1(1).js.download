	.button-container {
		width: var(--button-container--width, 100%);
		height: var(--button-container--height, 100%);
		margin: var(--button-container--margin-top, 0)
			var(--button-container--margin-right, 0)
			var(--button-container--margin-bottom, 0)
			var(--button-container--margin-left, 0);
		opacity: var(--button-container--opacity, 1);
		transition: var(--button-container--transition);
		display: var(--button-container--display);
		align-items: var(--button-container--align-items);
		justify-content: var(--button-container--justify-content);

		&:not(.disabled):hover {
			opacity: var(--button-container--opacity-hover);
		}

		&.disabled {
			--control-cursor: not-allowed;
			--button-container--opacity: var(
				--button-container--opacity-disabled,
				0.4
			);
		}

		&.round {
			height: var(--button-container__round--size);
			width: var(--button-container__round--size);
			border-radius: var(--button-container__round-border-radius, 50%);
			background-color: var(--button-container__round--background-color);

			&:hover {
				background-color: var(
					--button-container__round__hover--background-color,
					var(--button-container__round--background-color)
				);
				outline: var(--button-container__round__hover-outline);
			}
		}
	}

	.control {
		font-size: var(--control--font-size, 0);
		height: var(--control-height, inherit);
		width: var(--control-width, inherit);
		mask-image: var(--control--mask, unset);
		-webkit-mask-image: var(--control--mask, unset);
		mask-repeat: var(--control--mask-repeat, no-repeat);
		-webkit-mask-repeat: var(--control--mask-repeat, no-repeat);
		mask-size: var(--control--mask-size, contain);
		-webkit-mask-size: var(--control--mask-size, contain);
		mask-position: var(--control--mask-position, center);
		-webkit-mask-position: var(--control--mask-position, center);
		background-color: var(--controls-background-color, #f0f3f5);
		border: var(--control-border, none);
		cursor: var(--control-cursor, pointer);
		margin: var(--control--margin-top, 0) var(--control--margin-right, 0)
			var(--control--margin-bottom, 0) var(--control--margin-left, 0);
		padding: var(--control--padding);
		animation-name: var(--control--animation);
		animation-iteration-count: var(--control--animation-iteration-count);
		animation-timing-function: var(--control--animation-timing-function);
		animation-duration: var(--control--animation-duration);
		color: var(--control--font-color, inherit);
		pointer-events: auto;
	}

	.control.active {
		background-color: var(
			--controls--active-background-color,
			var(--controls-background-color)
		);
		color: var(--controls--active-font-color, inherit);
	}

	.control:hover {
		background-color: var(
			--controls--hover-background-color,
			var(--controls--active-background-color, var(--controls-background-color))
		);
		color: var(--controls--active-font-color, inherit);
		transform: var(--control--hover--transform);
	}

	.control:active {
		background-color: var(
			--controls--pressed-background-color,
			var(
				--controls--hover-background-color,
				var(
					--controls--active-background-color,
					var(--controls-background-color)
				)
			)
		);
		transform: var(--control--pressed--transform);
	}

	.control.active:hover {
		/* Fallback order:
		1. --controls--active-hover-background-color
		2. --controls--hover-background-color
		3. --controls--active-background-color
		4. --controls-background-color
		*/
		background-color: var(
			--controls--active-hover-background-color,
			var(
				--controls--hover-background-color,
				var(
					--controls--active-background-color,
					var(--controls-background-color)
				)
			)
		);
	}

	.control.hidden {
		display: var(--controls--display-none);
	}

	dialog::backdrop {
		--dialog-backdrop-color: white;
		--dialog-backdrop-opacity: 0.8;

		background-color: var(--dialog-backdrop-color);
		opacity: var(--dialog-backdrop-opacity);
	}
