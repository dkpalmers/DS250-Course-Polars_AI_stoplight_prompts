	:host {
		display: var(--controls__host--display);
		justify-content: var(--controls__host--justify-content);
		position: relative;
		width: var(--controls__host--width, fit-content);
		min-width: var(--controls__host--min-width);
		height: var(--controls__host--height, fit-content);
		margin-left: var(--controls__host--margin-left);
		margin-right: var(--controls__host--margin-right);
		margin-top: var(--controls__host--margin-top);
		margin-bottom: var(--controls__host--margin-bottom);
		pointer-events: auto;
	}

	:host(.active) {
		position: unset;
	}

