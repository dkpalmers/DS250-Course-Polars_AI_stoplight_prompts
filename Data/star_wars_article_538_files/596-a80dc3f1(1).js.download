		--control--mask: var(--muted-icon);
	}

	:host .volume-unmuted {
		--control--mask: var(--unmuted-icon);
	}

	:host .volume-half {
		--control--mask: var(--volume-half-icon);
	}

	:host .volume-full {
		--control--mask: var(--volume-full-icon);
	}

	.audio-control-container.volume-bar-visible {
		.volume-bar-container {
			pointer-events: all;
			opacity: 1;
			width: var(--volume-bar-container-from-left-width, 90px);
		}
		.control {
			background-color: var(
				--controls--active-background-color,
				var(--controls-background-color)
			);
		}
	}

	.audio-control-container:not(.volume-bar-visible) .volume-bar-container {
		pointer-events: none;
	}

	.audio-control-container.from-bottom:not(.volume-bar-visible)
		.volume-bar-container {
		height: 0;
		padding: 0;
	}

	.audio-control-container.from-left:not(.volume-bar-visible)
		.volume-bar-container {
		width: 0;
		padding: 0;
	}

	.volume-bar-container {
		opacity: 0;
	}

	.from-left {
		display: inline-flex;
		flex-direction: row;
		align-items: center;

		&.volume-bar-static,
		&.volume-bar-extended {
			display: inline-grid;
			grid-template-columns: 1fr 2fr;
			width: auto;
			padding-right: 10px;
		}

		&.volume-bar-extended {
			transition:
				margin 0.25s cubic-bezier(0.4, 0, 1, 1),
				width 0.25s cubic-bezier(0.4, 0, 1, 1);
		}

		.volume-bar-container {
			transition:
				opacity 0.2s,
				margin 0.2s cubic-bezier(0, 0, 0.2, 1),
				width 0.2s cubic-bezier(0, 0, 0.2, 1);
			max-height: var(--volume-bar-container-from-left-max-height, unset);
		}
	}

	.from-bottom {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;

		.volume-bar-container {
			transition: opacity 0.2s;
		}
	}

	.from-bottom > * {
		grid-area: 1 / 1;
	}
