		height: var(--play-button-svg--height);
		border-radius: var(--play-button-svg--border-radius);
	}

	.progress-ring {
		height: 48px;
		width: 48px;
		inset: 0px;
	}

	.progress-ring__circle {
		transform: rotate(-90deg);
		transform-origin: 50% 50%;
		animation: var(--progress-ring__circle--duration) linear countdown forwards;
		animation-play-state: var(--progress-ring__circle--animation-play-state);
	}

	.end-card-overlay__metadata {
		display: flex;
		flex-direction: column;
		gap: var(--metadata--gap);
		width: var(--metadata--width);
	}

	.end-card-overlay__countdown-text {
