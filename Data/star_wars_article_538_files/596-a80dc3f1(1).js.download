		:host {
			display: flex;
			justify-content: flex-end;
			flex-direction: column;
			position: absolute;
			z-index: 9999;
			width: 100%;
			height: 100%;
			top: 0px;
			pointer-events: none;
		}

		.promo-overlay__scrim {
			position: absolute;
			bottom: 0;
			left: 0;
			right: 0;
			height: 30%;
			background: linear-gradient(
				to top,
				rgba(0, 0, 0, 0.7) 0%,
				transparent 100%
			);
			transition: opacity 0.5s ease;
		}

		.promo-overlay__title-treatment {
			position: absolute;
			left: 20px;
			bottom: var(--promo-overlay__title-treatment--bottom, 100px);
			max-width: 40%;
			transition: all 0.3s ease;
		}

		.promo-overlay__title-treatment--low-position {
			bottom: 80px;
		}

		.promo-overlay__title-treatment img {
			width: auto;
			height: auto;
			object-fit: contain;
			max-height: var(--promo-overlay__title-treatment__img--max-height, 60px);
		}

		.promo-overlay__title-treatment span {
			color: white;
			font-size: 24px;
			text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
		}

		.promo-overlay__info-container {
			position: absolute;
			left: 20px;
			bottom: 80px;
			display: flex;
			align-items: center;
			gap: 12px;
			transition: opacity 0.5s ease;
		}

		.promo-overlay__rating {
			color: white;
			font-size: 16px;
			opacity: 1;
			transition: opacity 0.5s ease;
			display: flex;
			align-items: center;
		}

		.promo-overlay__separator {
			width: 1px;
			height: 16px;
			background: white;
		}

		.promo-overlay__promo {
			color: white;
			font-size: 1.1em;
			opacity: 1;
			transition: opacity 0.5s ease;
		}

		.promo-overlay__advisory-image {
			height: 20px;
			width: auto;
		}
