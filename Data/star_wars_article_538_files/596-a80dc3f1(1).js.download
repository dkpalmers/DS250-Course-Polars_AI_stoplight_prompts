		margin: 0px;
		font-family: var(--main-subtitle-font-family);
		font-size: var(--main-subtitle--font-size);
		font-weight: var(--main-subtitle--font-weight);
		line-height: var(--main-subtitle--line-height);
		text-transform: var(--main-subtitle--text-transform);
		text-overflow: var(--main-subtitle--text-overflow);
		overflow: var(--main-subtitle--overflow);
		display: var(--main-subtitle--display);
		-webkit-line-clamp: var(--main-subtitle--line-clamp);
		-webkit-box-orient: var(--main-subtitle---webkit-box-orient);
		line-clamp: var(--main-subtitle--line-clamp);
	}

	.end-card-overlay__cta-container {
		display: var(--cta-container--display);
		gap: var(--cta-container--gap);
		flex-direction: var(--cta-container--flex-direction);
		justify-content: var(--cta-container--justify-content);
		align-items: var(--cta-container--align-items);
	}

	.end-card-overlay__cta {
		display: var(--cta--display);
		width: var(--cta--width);
		height: var(--cta--height);
		padding: var(--cta--padding);
		justify-content: var(--cta--justify-content);
		align-items: var(--cta--align-items);
		border-radius: var(--cta--border-radius);
		font-family: var(--cta--font-family);
		font-size: var(--cta--font-size);
		font-weight: var(--cta--font-weight);
		line-height: var(--cta--line-height);
		border: var(--cta--border);
		cursor: var(--cta--cursor);
	}

	.end-card-overlay__cta-primary {
		background: var(--cta-primary--background);
		color: var(--cta-primary--color);
	}

	.end-card-overlay__cta-secondary {
		background: var(--cta-secondary--background);
		color: var(--cta-secondary--color);
	}

	.end-card-overlay__bottom-timer-container {
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 100%;
		height: var(--bottom-timer--height);
		background-color: var(--bottom-timer--background-color);
		overflow: hidden;
	}

	.end-card-overlay__bottom-timer {
		height: 100%;
		width: 100%;
		background-color: var(--bottom-timer--color);
		animation: var(--bottom-timer--duration) linear bottom-timer-countdown
			forwards;
		animation-play-state: var(--bottom-timer--animation-play-state);
	}

	.end-card-overlay__close-button {
		position: var(--close-button--position);
		top: var(--close-button--top);
		right: var(--close-button--right);
		width: var(--close-button--width);
