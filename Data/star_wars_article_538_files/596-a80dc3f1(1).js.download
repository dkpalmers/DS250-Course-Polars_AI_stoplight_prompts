	@keyframes countdown {
		from {
			stroke-dashoffset: var(--circumference);
		}
		to {
			stroke-dashoffset: 0;
		}
	}

	@keyframes bottom-timer-countdown {
		from {
			width: 0%;
		}
		to {
			width: 100%;
		}
	}

	.end-card-overlay__container {
		position: absolute;
		translate: var(--container--translate);
		height: var(--container--height);
		width: var(--container--width);
		display: flex;
		flex-direction: row;
		box-sizing: border-box;
		background-color: var(--container--background-color);
		border-radius: var(--container--border-radius);
		z-index: var(--container--z-index);
		padding: var(--container--padding);
		bottom: var(--container--bottom);
		right: var(--container--right);
		left: var(--container--left);
		transform: var(--container--transform);
		transition: var(--container--transition);
		inset: var(--end-card-overlay__container--inset);
	}

	.end-card-overlay__container.controls-open {
		margin-bottom: var(--container__controls-open--margin-bottom);
		transition: var(--container__controls-open--transition);
	}

	.end-card-overlay__container.bottom-timer {
		border-bottom-right-radius: var(--container--border-bottom-right-radius);
		border-bottom-left-radius: var(--container--border-bottom-left-radius);
	}

	.end-card-overlay__container.original {
		background-color: var(--container-original--background-color);
	}

	.end-card-overlay__container.takeover-visible {
		visibility: hidden;
	}

	.end-card-overlay__content {
		display: var(--content--display);
		flex-direction: var(--content--flex-direction);
		padding: var(--content--padding);
		gap: var(--content--gap);
		align-items: var(--content--align-items);
		justify-content: var(--content--justify-content);
		width: var(--content--width);
		min-width: var(--content--min-width);
	}

	.end-card-overlay__content-tile {
		padding: var(--content-tile--padding);
		border: var(--content-tile--border);
		aspect-ratio: var(--content-tile--aspect-ratio);
		display: var(--content-tile--display);
		border-radius: var(--content-tile--border-radius);
		background: var(--content-tile--background);
		background-size: var(--content-tile--background-size);
		background-position: var(--content-tile--background-position);
		background-repeat: var(--content-tile--background-repeat);
		justify-content: var(--content-tile--justify-content);
		align-items: var(--content-tile--align-items);
		cursor: var(--content-tile--cursor);
		max-height: var(--container--height);
	}

	.end-card-overlay__content-tile::before {
		content: "";
		display: block;
		position: var(--play-button-svg-before--position);
		mask-image: var(--play-button-svg-before--mask-image);
		-webkit-mask-image: var(--play-button-svg-before--mask-image, unset);
		mask-position: var(--play-button-svg-before--mask-position);
		-webkit-mask-position: var(--play-button-svg-before--mask-position, center);
		mask-repeat: var(--play-button-svg-before--mask-repeat, no-repeat);
