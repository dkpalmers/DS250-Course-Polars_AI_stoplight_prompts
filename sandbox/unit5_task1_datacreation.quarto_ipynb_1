        "    \"Benedict\", \"Callum\", \"Soren\", \"Leander\", \"Theron\",\n",
        "    \"Elowen\", \"Rowena\", \"Brielle\", \"Felicity\", \"Rosalind\",\n",
        "\n",
        "    # more contemporary variety\n",
        "    \"Caleb\", \"Ryan\", \"Nathan\", \"Christian\", \"Isaiah\",\n",
        "    \"Julian\", \"Thomas\", \"Wesley\", \"Miles\", \"Asher\",\n",
        "    \"Scarlett\", \"Madison\", \"Elena\", \"Maya\", \"Violet\",\n",
        "    \"Stella\", \"Caroline\", \"Ruby\", \"Alice\", \"Josephine\",\n",
        "\n",
        "    # a few rare but not too weird\n",
        "    \"Marcellus\", \"Lucian\", \"Cyrus\", \"Aurelia\", \"Helena\",\n",
