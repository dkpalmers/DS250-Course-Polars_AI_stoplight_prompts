      "source": [
        "Make the emails for each name\n"
      ],
      "id": "722ce734"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Set seed for reproducibility\n",
        "np.random.seed(42)\n",
        "\n",
        "# probabilities\n",
        "# gmail: 60%, org: 25%, yahoo: 15%\n",
        "probs = [0.6, 0.25, 0.15]\n",
        "domains = [\"gmail\", \"myorg\", \"yahoo\"]\n",
        "\n",
        "# create a random choice column\n",
        "rand_vals = np.random.rand(name_df.height)\n",
        "\n",
        "\n",
        "def assign_email(val):\n",
        "    if val < probs[0]:\n",
        "        domain = \"gmail\"\n",
        "    elif val < probs[0] + probs[1]:\n",
        "        domain = \"myorg\"\n",
        "    else:\n",
        "        domain = \"yahoo\"\n",
        "    \n",
        "    # Random capitalization\n",
        "    case_type = np.random.choice([\"upper\", \"lower\", \"random\"])\n",
        "    if case_type == \"upper\":\n",
        "        domain = domain.upper()\n",
        "    elif case_type == \"lower\":\n",
        "        domain = domain.lower()\n",
        "    else:  # random\n",
        "        domain = \"\".join([c.upper() if np.random.rand() > 0.5 else c.lower() for c in domain])\n",
        "    \n",
        "    # Random spaces\n",
        "    # if np.random.rand() < 0.2:\n",
        "    #     domain = \" \" + domain\n",
        "    if np.random.rand() < 0.2:\n",
        "        domain = domain + \" \"\n",
        "    \n",
        "    return domain\n",
        "\n",
        "# apply to Polars DataFrame\n",
        "email_col = [assign_email(v) for v in rand_vals]\n",
        "\n",
        "name_df = name_df.with_columns(\n",
        "    pl.Series(\"email_type\", email_col)\n",
        ")\n",
        "\n",
        "name_df.head(10)"
      ],
      "id": "6abeae56",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Now I need to create their actual gmail column\n"
      ],
      "id": "a68c35b1"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "STARTNUM = 54541\n",
        "\n",
        "# number of rows\n",
        "n_rows = name_df.height\n",
        "\n",
        "# random starting number between 0 and 90000\n",
        "start_num = STARTNUM\n",
        "\n",
        "# create sequential numbers starting from start_num, zero-padded 5 digits\n",
        "seq_nums = (pl.arange(0, n_rows, eager=True) + start_num).cast(pl.Utf8).str.zfill(5)\n",
        "\n",
        "# add the column to the dataframe\n",
        "name_df = name_df.with_columns([\n",
        "    seq_nums.alias(\"unique_num\")\n",
        "])\n",
        "\n",
        "# now build the email column\n",
        "name_df = name_df.with_columns([\n",
        "    pl.when(pl.col(\"email_type\").str.to_lowercase().str.contains(\"gmail\"))\n",
        "      .then(\n",
        "          pl.concat_str([\n",
        "              pl.col(\"first_name\").str.to_lowercase(),\n",
        "              pl.lit(\".\"),\n",
        "              pl.col(\"last_name\").str.to_lowercase(),\n",
        "              pl.lit(\"@\") + pl.col(\"email_type\")  # preserve jank\n",
        "          ])\n",
        "      )\n",
        "    .when(pl.col(\"email_type\").str.to_lowercase().str.contains(\"yahoo\"))\n",
        "      .then(\n",
        "          pl.concat_str([\n",
        "              pl.col(\"last_name\").str.to_lowercase(),\n",
        "              pl.lit(\"_\"),\n",
        "              pl.col(\"first_name\").str.to_lowercase(),\n",
        "              pl.lit(\"@\") + pl.col(\"email_type\")\n",
        "          ])\n",
        "      )\n",
        "    # .otherwise(\n",
        "    #     pl.concat_str([\n",
        "    #         pl.col(\"last_name\").str.slice(0,5).str.to_lowercase(),\n",
        "    #         pl.col(\"first_name\").str.slice(0,3).str.to_lowercase(),\n",
        "    #         pl.col(\"unique_num\"),  # unique per row\n",
        "    #         pl.lit(\"@\") + pl.col(\"email_type\")\n",
        "    #     ])\n",
        "    # )\n",
        "    .otherwise(\n",
        "        pl.concat_str([\n",
        "            pl.col(\"last_name\").str.to_lowercase(),\n",
        "            pl.col(\"unique_num\"),  # unique per row\n",
        "            pl.col(\"first_name\").str.to_lowercase(),\n",
        "            pl.lit(\"@\") + pl.col(\"email_type\")\n",
        "        ])\n",
        "    )\n",
        "    .alias(\"email\")\n",
        "])\n",
        "\n",
        "name_df.head(10)"
      ],
