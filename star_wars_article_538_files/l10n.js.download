company.com/en/current-privacy-policy/supplemental-privacy-policy-for-singapore/","links":[]},"pp_supplement_ph_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/supplemental-privacy-policy-for-philippines/","links":[]},"pp_supplement_jp_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/personal-data-of-our-guests-in-japan/","links":[]},"pp_supplement_br_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/data-protection-in-brazil/","links":[]},"privacy_policy_br_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/","links":[]},"pp_supplement_tw_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/supplemental-privacy-policy-for-taiwan/","links":[]},"pp_supplement_hk_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/supplemental-privacy-policy-for-hong-kong/","links":[]},"us_state_privacy_notice_phrase":{"text":"US State Privacy Rights Notice","links":[]},"us_state_privacy_document_code":{"text":"US_STATE_PRIVACY_RIGHTS.DEFAULT.en-US","links":[]},"us_state_privacy_notice_url":{"text":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/your-us-state-privacy-rights/","links":[]},"us_state_privacy_notice_link":{"text":"US State Privacy Rights Notice","links":[{"documentCode":"US_STATE_PRIVACY_RIGHTS.DEFAULT.en-US","href":"https://web.archive.org/web/20260225230050/https://privacy.thewaltdisneycompany.com/en/current-privacy-policy/your-us-state-privacy-rights/","start":0,"text":"US State Privacy Rights Notice"}]},"ca_supplemental_privacy_phrase":{"text":"Supplemental Privacy Policy F